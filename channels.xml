<?xml version="1.0" encoding="UTF-8"?>
<!--
  Channel list for the iptv-org/epg grabber (https://github.com/iptv-org/epg).

  NOTE: this fetch runs in GitHub Actions via .github/workflows/epg.yml, not
  in the Claude sandbox (which has no outbound network).

  HOW IT WORKS.
  Each channel needs:
    site      = a folder name under the grabber's `sites/` directory
    site_id   = that source's own id for the channel
    xmltv_id  = MUST match the `epgId` in data/channels.js so the converter
                (scripts/xmltv-to-guide.mjs) attaches the listings to the card.

  ONLY VERIFIED CHANNELS ARE LISTED HERE.
  Every site_id below was taken from the grabber's own committed channel catalog
  (sites/freeview.co.uk/freeview.co.uk.channels.xml and
   sites/player.ee.co.uk/player.ee.co.uk.channels.xml), so the IDs are real.
  (Whether each returns data on a given day can only be confirmed by an actual
  online grab.) Channels in data/channels.js without a line here have no verified
  free UK source and are left to the app's synthetic schedule; that currently
  includes Disney Junior/Channel, BabyTV, CNN, Al Jazeera, CNBC, Bloomberg,
  Nat Geo / Nat Geo Wild, Travel, E!, AMC, Syfy, the AXN and Star feeds,
  Hollywood and MTV Live.

  The workflow grabs into guide.xml then runs scripts/xmltv-to-guide.mjs to
  produce data/guide.json. See .github/workflows/epg.yml for the exact commands.
-->
<channels>
  <!-- UK terrestrial via freeview.co.uk (region: London; UK timezone) -->
  <channel site="freeview.co.uk" lang="en" xmltv_id="BBCOne.uk" site_id="64257#4164">BBC One</channel>
  <channel site="freeview.co.uk" lang="en" xmltv_id="BBCTwo.uk" site_id="64257#4287">BBC Two</channel>
  <channel site="freeview.co.uk" lang="en" xmltv_id="BBCNews.uk" site_id="64257#4352">BBC News</channel>
  <channel site="freeview.co.uk" lang="en" xmltv_id="ITV1.uk" site_id="64257#8261">ITV</channel>
  <channel site="freeview.co.uk" lang="en" xmltv_id="ITV4.uk" site_id="64257#8330">ITV4</channel>
  <channel site="freeview.co.uk" lang="en" xmltv_id="Channel4.uk" site_id="64257#8384">Channel 4</channel>
  <channel site="freeview.co.uk" lang="en" xmltv_id="Channel5.uk" site_id="64257#8500">Channel 5</channel>
  <!-- Via player.ee.co.uk (EE TV UK guide; UK timezone) -->
  <channel site="player.ee.co.uk" lang="en" xmltv_id="SkyNews.uk" site_id="dvb://233a..5640">Sky News</channel>
  <channel site="player.ee.co.uk" lang="en" xmltv_id="SkyMax.uk" site_id="http://bds.tv/services/BT_255_1402_SD">Sky One (now Sky Max)</channel>
  <channel site="player.ee.co.uk" lang="en" xmltv_id="CBeebies.uk" site_id="dvb://233a..1240">CBeebies</channel>
  <channel site="player.ee.co.uk" lang="en" xmltv_id="CBBC.uk" site_id="dvb://233a..1200">CBBC</channel>
  <channel site="player.ee.co.uk" lang="en" xmltv_id="NickJr.uk" site_id="http://bds.tv/services/BT_750608_1857_SD">Nick Jr.</channel>
  <channel site="player.ee.co.uk" lang="en" xmltv_id="Nickelodeon.uk" site_id="http://bds.tv/services/BT_154274_1846_SD">Nickelodeon</channel>
  <channel site="player.ee.co.uk" lang="en" xmltv_id="CartoonNetwork.uk" site_id="http://bds.tv/services/BT_157644_5601_SD">Cartoon Network</channel>
  <channel site="player.ee.co.uk" lang="en" xmltv_id="Discovery.uk" site_id="http://bds.tv/services/BT_608791">Discovery</channel>
