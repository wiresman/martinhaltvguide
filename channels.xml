<!--
  Channel list for the iptv-org/epg grabber (https://github.com/iptv-org/epg).

  HOW IT WORKS
  ------------
  Each <channel> needs three things:
    site      - which guide source to scrape (a folder name in iptv-org/epg's
                `sites/` directory, e.g. "freeview.co.uk" or "player.ee.co.uk")
    site_id   - that source's own id for the channel (taken from the site's
                committed <site>.channels.xml in iptv-org/epg)
    xmltv_id  - this MUST match the `epgId` value in data/channels.js so the
                converter (scripts/xmltv-to-guide.mjs) can attach the listings.

  Browse channels + ids at https://iptv-org.github.io/ and the supported sites
  at https://github.com/iptv-org/epg/tree/master/sites .

  SOURCES USED HERE (both UK guides, so times are UK local / correct):
    freeview.co.uk    - UK terrestrial channels (BBC One/Two/News, ITV, ITV4,
                        Channel 4). site_id is "nid#sid" from Freeview's API.
    player.ee.co.uk   - EE TV's UK guide; everything else below.

  Every channel in this file was verified to return real <programme> data from
  the grabber (run 2026-05-30). Channels in data/channels.js without a line
  here -- Channel 5, the AXN / Star / Hollywood / AMC* / MTV Live feeds -- have
  no working public UK source in iptv-org and fall back to the app's synthetic
  schedule. (* AMC is not listed by either source above.)

  Grab with:
    npm run grab -- --channels=ABS/channels.xml --output=ABS/guide.xml --days=2
  then convert:
    node scripts/xmltv-to-guide.mjs ABS/guide.xml data/guide.json
-->
<channels>
  <!-- UK terrestrial via freeview.co.uk (site_id = "nid#sid") -->
  <channel site="freeview.co.uk" lang="en" xmltv_id="BBCOne.uk" site_id="64257#4164">BBC One</channel>
  <channel site="freeview.co.uk" lang="en" xmltv_id="BBCTwo.uk" site_id="64257#4287">BBC Two</channel>
  <channel site="freeview.co.uk" lang="en" xmltv_id="BBCNews.uk" site_id="64257#4352">BBC News</channel>
  <channel site="freeview.co.uk" lang="en" xmltv_id="ITV1.uk" site_id="64257#8261">ITV</channel>
  <channel site="freeview.co.uk" lang="en" xmltv_id="ITV4.uk" site_id="64257#8330">ITV4</channel>
  <channel site="freeview.co.uk" lang="en" xmltv_id="Channel4.uk" site_id="64257#8384">Channel 4</channel>
  <!-- Everything else via player.ee.co.uk (EE TV, UK guide) -->
  <channel site="player.ee.co.uk" lang="en" xmltv_id="SkyShowcase.uk" site_id="dvb://233a..4440">Sky Showcase</channel>
