<?xml version="1.0" encoding="UTF-8"?>
<!--
  Channel list for the iptv-org/epg grabber (https://github.com/iptv-org/epg).

  HOW IT WORKS
  ------------
  Each <channel> needs three things:
    site      - which guide source to scrape (a folder name in iptv-org/epg's
                `sites/` directory, e.g. "freeview.co.uk" or "player.ee.co.uk")
    site_id   - that source's own id for the channel
    xmltv_id  - this MUST match the `epgId` value in data/channels.js so the
                converter (scripts/xmltv-to-guide.mjs) can attach the listings.

  Browse channels + ids at https://iptv-org.github.io/ and the supported sites
  at https://github.com/iptv-org/epg/tree/master/sites .

  SOURCES USED HERE
  -----------------
    freeview.co.uk    - UK terrestrial channels (BBC/ITV/C4/C5). UK timezone.
    player.ee.co.uk   - EE TV's UK guide; everything else below. UK timezone.

  Every channel in this file was verified to return real <programme> data from
  the grabber. Channels in data/channels.js without a line here (e.g. the
  AXN / Star / Hollywood / MTV Live feeds, which have no working public UK
  source in iptv-org) are left to the app's synthetic schedule.

  Grab with:
    npm run grab -- --channels=ABS/channels.xml --output=ABS/guide.xml --days=2
  then convert:
    node scripts/xmltv-to-guide.mjs ABS/guide.xml data/guide.json
-->
<channels>
  <!-- UK terrestrial via freeview.co.uk -->
  <channel site="freeview.co.uk" lang="en" xmltv_id="BBCOne.uk" site_id="64983">BBC One</channel>
  <channel site="freeview.co.uk" lang="en" xmltv_id="BBCTwo.uk" site_id="64984">BBC Two</channel>
  <channel site="freeview.co.uk" lang="en" xmltv_id="BBCNews.uk" site_id="64922">BBC News</channel>
  <channel site="freeview.co.uk" lang="en" xmltv_id="ITV1.uk" site_id="64959">ITV</channel>
